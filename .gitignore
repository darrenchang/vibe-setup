# --- Node BS ---
node_modules
package-lock.json
package.json

# --- OpenClaw Private Data ---
.openclaw/memory/
.openclaw/state/
.openclaw/agents/*/agent/auth-*.json
.openclaw/agents/*/agent/auth-state.json
.openclaw/agents/*/agent/models.json

# --- Session & Transient Data ---
.openclaw/**/*.json
! .openclaw/openclaw.json  # Allow the structural config, but...
# (Note: If you put passwords in openclaw.json, 
#  it's better to use an environment variable or a separate .env file)

# --- Local Environment Specifics ---
.openclaw/openclaw.json.bak*
